   :body "use std::collections::BTreeMap;\n\nuse serde::Deserialize;\nuse snapbox::assert_data_eq;\nuse snapbox::prelude::*;\nuse snapbox::str;\n\n#[derive(Debug, Deserialize, PartialEq)]\nstruct Document<K: Ord> {\n    map: Map<K>,\n}\n\ntype Map<K> = BTreeMap<K, String>;\n\nmod string_key {\n    use super::*;\n\n    type Map = super::Map<String>;\n    type Document = super::Document<String>;\n\n    #[test]\n    fn from_str() {\n        let input = \"key = 'value'\";\n        let expected = str![[r#\"\n{\n    \"key\": \"value\",\n}\n\n\"#]];\n        let result = crate::from_str::<Map>(input);\n        assert_data_eq!(result.unwrap().to_debug(), expected);\n    }\n\n    #[test]\n    fn value_from_inline_table() {\n        let input = \"{ key = 'value' }\";\n        let expected = str![[r#\"\n{\n    \"key\": \"value\",\n}\n\n\"#]];\n        let result = crate::value_from_str::<Map>(input);\n        assert_data_eq!(result.unwrap().to_debug(), expected);\n    }\n\n    #[test]\n    fn from_inline_table() {\n        let input = \"map = { key = 'value' }\";\n        let expected = str![[r#\"\nDocument {\n    map: {\n        \"key\": \"value\",\n    },\n}\n\n\"#]];\n        let result = crate::from_str::<Document>(input);\n        assert_data_eq!(result.unwrap().to_debug(), expected);\n    }\n\n    #[test]\n    fn from_std_table() {\n        let input = \"[map]\nkey = 'value'\";\n        let expected = str![[r#\"\nDocument {\n    map: {\n        \"key\": \"value\",\n    },\n}\n\n\"#]];\n        let result = crate::from_str::<Document>(input);\n        assert_data_eq!(result.unwrap().to_debug(), expected);\n    }\n}\n\nmod variant_key {\n    use super::*;\n\n    #[derive(Debug, Deserialize, PartialEq, Eq, PartialOrd, Ord)]\n    enum Keys {\n        #[allow(non_camel_case_types)]\n        key,\n    }\n\n    type Map = super::Map<Keys>;\n    type Document = super::Document<Keys>;\n\n    #[test]\n    fn from_str() {\n        let input = \"key = 'value'\";\n        let expected = str![[r#\"\n{\n    key: \"value\",\n}\n\n\"#]];\n        let result = crate::from_str::<Map>(input);\n        assert_data_eq!(result.unwrap().to_debug(), expected);\n    }\n\n    #[test]\n    fn value_from_inline_table() {\n        let input = \"{ key = 'value' }\";\n        let expected = str![[r#\"\n{\n    key: \"value\",\n}\n\n\"#]];\n        let result = crate::value_from_str::<Map>(input);\n        assert_data_eq!(result.unwrap().to_debug(), expected);\n    }\n\n    #[test]\n    fn from_inline_table() {\n        let input = \"map = { key = 'value' }\";\n        let expected = str![[r#\"\nDocument {\n    map: {\n        key: \"value\",\n    },\n}\n\n\"#]];\n        let result = crate::from_str::<Document>(input);\n        assert_data_eq!(result.unwrap().to_debug(), expected);\n    }\n\n    #[test]\n    fn from_std_table() {\n        let input = \"[map]\nkey = 'value'\";\n        let expected = str![[r#\"\nDocument {\n    map: {\n        key: \"value\",\n    },\n}\n\n\"#]];\n        let result = crate::from_str::<Document>(input);\n        assert_data_eq!(result.unwrap().to_debug(), expected);\n    }\n}\n\nmod bool_key {\n    use super::*;\n\n    type Map = super::Map<bool>;\n    type Document = super::Document<bool>;\n\n    #[test]\n    fn from_str() {\n        let input = \"'false' = 'value'\";\n        let expected = str![[r#\"\n{\n    false: \"value\",\n}\n\n\"#]];\n        let result = crate::from_str::<Map>(input);\n        assert_data_eq!(result.unwrap().to_debug(), expected);\n    }\n\n    #[test]\n    fn value_from_inline_table() {\n        let input = \"{ 'false' = 'value' }\";\n        let expected = str![[r#\"\n{\n    false: \"value\",\n}\n\n\"#]];\n        let result = crate::value_from_str::<Map>(input);\n        assert_data_eq!(result.unwrap().to_debug(), expected);\n    }\n\n    #[test]\n    fn from_inline_table() {\n        let input = \"map = { 'false' = 'value' }\";\n        let expected = str![[r#\"\nDocument {\n    map: {\n        false: \"value\",\n    },\n}\n\n\"#]];\n        let result = crate::from_str::<Document>(input);\n        assert_data_eq!(result.unwrap().to_debug(), expected);\n    }\n\n    #[test]\n    fn from_std_table() {\n        let input = \"[map]\n'false' = 'value'\";\n        let expected = str![[r#\"\nDocument {\n    map: {\n        false: \"value\",\n    },\n}\n\n\"#]];\n        let result = crate::from_str::<Document>(input);\n        assert_data_eq!(result.unwrap().to_debug(), expected);\n    }\n}\n\nmod i16_key {\n    use super::*;\n\n    type Map = super::Map<i16>;\n    type Document = super::Document<i16>;\n\n    #[test]\n    fn from_str() {\n        let input = \"'42' = 'value'\";\n        let expected = str![[r#\"\n{\n    42: \"value\",\n}\n\n\"#]];\n        let result = crate::from_str::<Map>(input);\n        assert_data_eq!(result.unwrap().to_debug(), expected);\n    }\n\n    #[test]\n    fn value_from_inline_table() {\n        let input = \"{ '42' = 'value' }\";\n        let expected = str![[r#\"\n{\n    42: \"value\",\n}\n\n\"#]];\n        let result = crate::value_from_str::<Map>(input);\n        assert_data_eq!(result.unwrap().to_debug(), expected);\n    }\n\n    #[test]\n    fn from_inline_table() {\n        let input = \"map = { '42' = 'value' }\";\n        let expected = str![[r#\"\nDocument {\n    map: {\n        42: \"value\",\n    },\n}\n\n\"#]];\n        let result = crate::from_str::<Document>(input);\n        assert_data_eq!(result.unwrap().to_debug(), expected);\n    }\n\n    #[test]\n    fn from_std_table() {\n        let input = \"[map]\n'42' = 'value'\";\n        let expected = str![[r#\"\nDocument {\n    map: {\n        42: \"value\",\n    },\n}\n\n\"#]];\n        let result = crate::from_str::<Document>(input);\n        assert_data_eq!(result.unwrap().to_debug(), expected);\n    }\n}\n\nmod char_key {\n    use super::*;\n\n    type Map = super::Map<char>;\n    type Document = super::Document<char>;\n\n    #[test]\n    fn from_str() {\n        let input = \"k = 'value'\";\n        let expected = str![[r#\"\n{\n    'k': \"value\",\n}\n\n\"#]];\n        let result = crate::from_str::<Map>(input);\n        assert_data_eq!(result.unwrap().to_debug(), expected);\n    }\n\n    #[test]\n    fn value_from_inline_table() {\n        let input = \"{ k = 'value' }\";\n        let expected = str![[r#\"\n{\n    'k': \"value\",\n}\n\n\"#]];\n        let result = crate::value_from_str::<Map>(input);\n        assert_data_eq!(result.unwrap().to_debug(), expected);\n    }\n\n    #[test]\n    fn from_inline_table() {\n        let input = \"map = { k = 'value' }\";\n        let expected = str![[r#\"\nDocument {\n    map: {\n        'k': \"value\",\n    },\n}\n\n\"#]];\n        let result = crate::from_str::<Document>(input);\n        assert_data_eq!(result.unwrap().to_debug(), expected);\n    }\n\n    #[test]\n    fn from_std_table() {\n        let input = \"[map]\nk = 'value'\";\n        let expected = str![[r#\"\nDocument {\n    map: {\n        'k': \"value\",\n    },\n}\n\n\"#]];\n        let result = crate::from_str::<Document>(input);\n        assert_data_eq!(result.unwrap().to_debug(), expected);\n    }\n}\n"} {:path "crates/toml/tests/serde/de_errors.rs"
