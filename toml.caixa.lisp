   :sha256 "50cc02928805a2c742b3285f0c9c8d414eda3b9ce8da27db49cd4b8e6711efce"
   :size 383
   :body "[package]\nname = \"toml_edit_fuzz\"\nversion = \"0.0.0\"\nedition.workspace = true\nrust-version.workspace = true\npublish = false\n\n[package.metadata.release]\nrelease = false\n\n[package.metadata]\ncargo-fuzz = true\n\n[dependencies]\nlibfuzzer-sys = \"0.4.12\"\ntoml_edit = { path = \"../toml_edit\" }\n\n[[bin]]\nname = \"parse_document\"\npath = \"parse_document.rs\"\ntest = false\n\n[lints]\nworkspace = true\n"} {:path "crates/toml_edit_fuzz/README.md"
   :sha256 "a522058bd866718e82245340788133180e6133e828309d2182a939f4bc414c2a"
   :size 164
   :body "# How to run\n\n```\n$ # install cargo fuzz (if you don't have it)\n$ cargo install cargo-fuzz\n$ # run fuzzer\n$ cargo +nightly fuzz run parse_document --fuzz-dir=.\n```\n"} {:path "crates/toml_edit_fuzz/.gitignore"
   :sha256 "d70acf7adc4324602f5da9a60787135461cdd8e6e78450098c003de3578c1216"
   :size 29
   :body "target/\ncorpus/\nrun-fuzzer.sh"} {:path "crates/toml_edit_fuzz/seeds/0001"
   :sha256 "69a99e7ff269c71b8bf39435a72b908f25fbb05c02ae956ba7b26a8a01cf6bab"
   :size 644
   :body "# This is a TOML document.\n\ntitle = \"TOML Example\"\n\n    [owner]\n    name = \"Tom Preston-Werner\"\n    dob = 1979-05-27T07:32:00-08:00 # First class dates\n\n    [database]\n    server = \"192.168.1.1\"\n    ports = [ 8001, 8001, 8002 ]\n    connection_max = 5000\n    enabled = true\n\n[[bin]]\nwow = \"such array of tables\"\n\n    [servers]\n\n    # Indentation (tabs and/or spaces) is allowed but not required\n[servers.alpha]\n    ip = \"10.0.0.1\"\n    dc = \"eqdc10\"\n\n    [servers.beta]\n    ip = \"10.0.0.2\"\n    dc = \"eqdc10\"\n\n    [clients]\n    data = [ [\"gamma\", \"delta\"], [1, 2] ]\n\n    # Line breaks are OK when inside arrays\nhosts = [\n    \"alpha\",\n    \"omega\"\n]"} {:path "crates/toml_edit_fuzz/parse_document.rs"
   :sha256 "1d14145b9ebe68579821963359950e1007cba16754d0cb725eeb64f50aed867b"
   :size 882
   :body "#![no_main]\n\nuse toml_edit::DocumentMut;\n\nlibfuzzer_sys::fuzz_target!(|data: &[u8]| -> libfuzzer_sys::Corpus {\n    let Ok(data) = std::str::from_utf8(data) else {\n        return libfuzzer_sys::Corpus::Reject;\n    };\n\n    let doc = match data.parse::<DocumentMut>() {\n        Ok(doc) => doc,\n        Err(err) => {\n            println!(\n                \"parse error: {err}\n\ndata:\n```toml\n{data}\n```\n\"\n            );\n            return libfuzzer_sys::Corpus::Keep;\n        }\n    };\n    let toml = doc.to_string();\n    let doc = toml.parse::<DocumentMut>();\n    assert!(\n        doc.is_ok(),\n        \"parse error: {}\n\ndata:\n```toml\n{data}\n```\n\ndoc.to_string():\n```toml\n{}\n```\",\n        doc.unwrap_err(),\n        toml\n    );\n    let doc = doc.unwrap();\n    assert_eq!(\n        doc.to_string(),\n        toml,\n        \"data:\n```toml\n{data}\n```\n\"\n    );\n    libfuzzer_sys::Corpus::Keep\n});\n"} {:path "crates/toml_writer/Cargo.toml"
   :sha256 "318d55c322a2cbfd9646020253f5a4809eb26046d93ddcabfc783f7a8f649198"
   :size 1228
   :body "[package]\nname = \"toml_writer\"\nversion = \"1.1.1+spec-1.1.0\"\ndescription = \"\"\"\nA low-level interface for writing out TOML\n\"\"\"\ncategories = [\"encoding\"]\nkeywords = [\"encoding\", \"toml\", \"no_std\"]\nrepository.workspace = true\nlicense.workspace = true\nedition.workspace = true\nrust-version.workspace = true\ninclude.workspace = true\n\n[package.metadata.docs.rs]\nall-features = true\nrustdoc-args = [\"--generate-link-to-definition\"]\n\n[package.metadata.release]\npre-release-replacements = [\n  {file=\"CHANGELOG.md\", search=\"Unreleased\", replace=\"{{version}}\", min=1},\n  {file=\"CHANGELOG.md\", search=\"\\\\.\\\\.\\\\.HEAD\", replace=\"...{{tag_name}}\", exactly=1},\n  {file=\"CHANGELOG.md\", search=\"ReleaseDate\", replace=\"{{date}}\", min=1},\n  {file=\"CHANGELOG.md\", search=\"<!-- next-header -->\", replace=\"<!-- next-header -->\\n## [Unreleased] - ReleaseDate\\n\", exactly=1},\n  {file=\"CHANGELOG.md\", search=\"<!-- next-url -->\", replace=\"<!-- next-url -->\\n[Unreleased]: https://github.com/toml-rs/toml/compare/{{tag_name}}...HEAD\", exactly=1},\n]\n\n[features]\ndefault = [\"std\"]\nstd = [\"alloc\"]\nalloc = []\n\n[dependencies]\n\n[dev-dependencies]\nproptest = \"1.10.0\"\nsnapbox = \"1.1.0\"\ntoml_old = { version = \"0.5.11\", package = \"toml\" }\n\n[lints]\nworkspace = true\n"} {:path "crates/toml_writer/CHANGELOG.md"
